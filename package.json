{
  "name": "birr-finance",
  "version": "0.1.0",
  "main": "index.ts",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "test": "jest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "react-native-unistyles/mocks",
      "<rootDir>/src/theme/unistyles.ts",
      "<rootDir>/jest.setup.js"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.1",
    "@expo-google-fonts/space-mono": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "culori": "^4.0.1",
    "expo": "56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-nitro-modules": "0.35.9",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-unistyles": "^3.2.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/culori": "^4.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.39.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@react-native/gradle-plugin@0.85.3": "patches/@react-native__gradle-plugin@0.85.3.patch"
    }
  }
}
